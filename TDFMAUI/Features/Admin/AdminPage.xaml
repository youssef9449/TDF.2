<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:TDFMAUI.ViewModels"
             x:Class="TDFMAUI.Features.Admin.AdminPage" 
             Title="Admin"
             x:DataType="viewmodels:AdminViewModel">

    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Header -->
        <HorizontalStackLayout Grid.Row="0" Padding="20">
            <Button Text="←" Command="{Binding BackCommand}" BackgroundColor="Transparent" TextColor="{StaticResource Primary}" FontSize="20" WidthRequest="50"/>
            <Label Text="Admin Panel" FontSize="24" FontAttributes="Bold" HorizontalOptions="CenterAndExpand"/>
        </HorizontalStackLayout>

        <!-- Content -->
        <Grid Grid.Row="1" Padding="20" ColumnDefinitions="*,*" RowDefinitions="Auto">
            <Frame BackgroundColor="{StaticResource Primary}" Padding="15" CornerRadius="15" Grid.Column="0">
                <VerticalStackLayout Spacing="15">
                    <Label Text="Users" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource OnPrimaryColor}"/>
                    <Button Text="Add User" Command="{Binding AddUserCommand}" BackgroundColor="{StaticResource SurfaceColor}" TextColor="{StaticResource Primary}" CornerRadius="10"/>
                </VerticalStackLayout>
            </Frame>
            
            <Frame BackgroundColor="{StaticResource Primary}" Padding="15" CornerRadius="15" Grid.Column="1" Margin="10,0,0,0">
                 <VerticalStackLayout Spacing="15">
                    <Label Text="Requests" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource OnPrimaryColor}"/>
                    <Button Text="Manage Requests" Command="{Binding ManageRequestsCommand}" BackgroundColor="{StaticResource SurfaceColor}" TextColor="{StaticResource Primary}" CornerRadius="10"/>
                </VerticalStackLayout>
            </Frame>
        </Grid>
    </Grid>
</ContentPage>
