<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:helpers="clr-namespace:TDFMAUI.Helpers"
             xmlns:vm="clr-namespace:TDFMAUI.ViewModels"
             xmlns:dtos="clr-namespace:TDFShared.DTOs.Messages;assembly=TDFShared"
             xmlns:pages="clr-namespace:TDFMAUI.Pages"
             xmlns:converters="clr-namespace:TDFMAUI.Converters"
             x:DataType="vm:MessagesViewModel"
             x:Class="TDFMAUI.Pages.MessagesPage"
             Title="Messages"
             BackgroundColor="{DynamicResource Gray100}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*,Auto" Padding="{OnIdiom Phone='10', Default='15'}">
        
        <!-- Responsive Header -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,15">
            <Label Text="Messages" 
                   FontSize="{OnIdiom Phone=20, Default=24}" 
                   FontAttributes="Bold"
                   VerticalOptions="Center" />
            
            <!-- Desktop/Tablet Button Layout -->
            <HorizontalStackLayout Grid.Column="1" Spacing="10"
                                   IsVisible="{x:Static helpers:DeviceHelper.IsLargeScreen}">
                <Button Text="New Message"
                        Clicked="OnNewMessageClicked"
                        Style="{StaticResource ButtonPrimary}" 
                        HeightRequest="40"
                        WidthRequest="120"/>
                <Button Text="↻"
                        Command="{Binding LoadMessagesCommand}"
                        Style="{StaticResource ButtonSecondaryCircular}" 
                        HeightRequest="40"
                        WidthRequest="40" />
            </HorizontalStackLayout>

            <!-- Phone Button Layout -->
             <VerticalStackLayout Grid.Column="1" Spacing="5" HorizontalOptions="End"
                                 IsVisible="{x:Static helpers:DeviceHelper.UseCompactUI}">
                 <Button Text="New Message"
                        Clicked="OnNewMessageClicked"
                        Style="{StaticResource ButtonPrimary}" 
                        HeightRequest="35"
                        FontSize="12" />
                <Button Text="↻"
                        Command="{Binding LoadMessagesCommand}"
                        Style="{StaticResource ButtonSecondaryCircular}" 
                        HeightRequest="35"
                        WidthRequest="35" />
            </VerticalStackLayout>
        </Grid>
        
        <!-- Messages list -->
        <RefreshView Grid.Row="1" Command="{Binding LoadMessagesCommand}" IsRefreshing="{Binding IsLoading}" RefreshColor="{StaticResource Primary}">
            <ScrollView>
                <VerticalStackLayout> 
                    <!-- Constrain width on Desktop/Tablet -->
                    <VerticalStackLayout.MaximumWidthRequest>
                        <OnIdiom x:TypeArguments="x:Double" Phone="10000" Tablet="800" Desktop="700" />
                    </VerticalStackLayout.MaximumWidthRequest>
                    <VerticalStackLayout.HorizontalOptions>
                         <OnIdiom Default="Fill" Phone="Fill" Tablet="Center" Desktop="Center" />
                    </VerticalStackLayout.HorizontalOptions>

                    <CollectionView ItemsSource="{Binding Messages}" 
                                    SelectionMode="None"
                                    EmptyView="No messages to display">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="vm:MessageItemViewModel">
                                <Frame Margin="0,5" 
                                       Padding="{OnIdiom Phone='10', Default='15'}" 
                                       BackgroundColor="{Binding BackgroundColor}"
                                       CornerRadius="10"
                                       BorderColor="{DynamicResource Gray300}">
                                    <Grid>
                                        <!-- Desktop/Tablet Layout -->
                                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto"
                                              IsVisible="{x:Static helpers:DeviceHelper.IsLargeScreen}">
                                            <!-- Sender with online status -->
                                            <Grid Grid.Row="0" 
                                                  Grid.Column="0"
                                                  ColumnDefinitions="Auto,*">
                                                
                                                       
                                                <Label Grid.Column="1"
                                                       Text="{Binding SenderName}" 
                                                       FontAttributes="Bold"
                                                       FontSize="16" />
                                            </Grid>
                                            
                                            <!-- Message preview -->
                                            <Label Grid.Row="1"
                                                   Grid.Column="0"
                                                   Text="{Binding Content, Mode=OneWay}" 
                                                   MaxLines="2"
                                                   LineBreakMode="TailTruncation"
                                                   TextColor="{DynamicResource Gray600}"
                                                   Margin="0,5,0,0" />
                                            
                                            <!-- Date -->
                                            <Label Grid.Row="2"
                                                   Grid.Column="0"
                                                   Text="{Binding SentAt, StringFormat='{0:g}'}" 
                                                   FontSize="12"
                                                   TextColor="{DynamicResource Gray500}"
                                                   Margin="0,5,0,0" />
                                            
                                        </Grid>
                                        
                                        <!-- Mobile Layout -->
                                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="2" IsVisible="{x:Static helpers:DeviceHelper.UseCompactUI}">
                                            <Label Grid.Column="0" Grid.Row="0" Text="{Binding SenderName}" FontAttributes="Bold" FontSize="14" />
                                            <Label Grid.Column="1" Grid.Row="0" Text="{Binding Timestamp, StringFormat='{0:t}'}" FontSize="10" TextColor="{DynamicResource Gray500}" HorizontalOptions="End"/>
                                            <Label Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Text="{Binding Content}" MaxLines="1" LineBreakMode="TailTruncation" TextColor="{DynamicResource Gray600}" FontSize="12" />
                                        </Grid>
                                    </Grid>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
             </ScrollView>
        </RefreshView>
    </Grid>
</ContentPage>