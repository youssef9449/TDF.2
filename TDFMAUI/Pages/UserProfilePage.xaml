<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:TDFMAUI.ViewModels"
             xmlns:converters="clr-namespace:TDFMAUI.Converters"
             xmlns:helpers="clr-namespace:TDFMAUI.Helpers"
             x:Class="TDFMAUI.Pages.UserProfilePage"
             Title="{Binding Title}"
             x:DataType="viewmodels:UserProfileViewModel"
             BackgroundColor="{Binding Source={x:Static helpers:ThemeHelper.CurrentTheme}, Converter={StaticResource ThemeToBackgroundColorConverter}}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:BooleanInverter x:Key="BooleanInverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid>
        <ScrollView>
            <VerticalStackLayout Padding="20" Spacing="20" HorizontalOptions="Center">
                <VerticalStackLayout.MaximumWidthRequest>
                    <OnIdiom x:TypeArguments="x:Double" Phone="10000" Tablet="800" Desktop="700" />
                </VerticalStackLayout.MaximumWidthRequest>

                <Frame CornerRadius="100" HeightRequest="200" WidthRequest="200" Padding="0" IsClippedToBounds="True" HorizontalOptions="Center">
                    <Image Aspect="AspectFill" Source="{Binding ProfileImage}" />
                </Frame>
                
                <Button Text="Change Photo" Command="{Binding ChangeImageCommand}" IsVisible="{Binding IsEditing}" HorizontalOptions="Center" />

                <Frame BackgroundColor="{StaticResource SurfaceColor}" Padding="20">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Full Name" FontAttributes="Bold" />
                        <Label Text="{Binding CurrentUser.FullName}" IsVisible="{Binding IsEditing, Converter={StaticResource BooleanInverter}}" />
                        <Entry Text="{Binding EditingUser.FullName}" IsVisible="{Binding IsEditing}" />

                        <Label Text="Department" FontAttributes="Bold" />
                        <Label Text="{Binding CurrentUser.Department}" IsVisible="{Binding IsEditing, Converter={StaticResource BooleanInverter}}" />
                        <Entry Text="{Binding EditingUser.Department}" IsVisible="{Binding IsEditing}" />

                        <Label Text="Title" FontAttributes="Bold" />
                        <Label Text="{Binding CurrentUser.Title}" IsVisible="{Binding IsEditing, Converter={StaticResource BooleanInverter}}" />
                        <Entry Text="{Binding EditingUser.Title}" IsVisible="{Binding IsEditing}" />
                    </VerticalStackLayout>
                </Frame>

                <HorizontalStackLayout HorizontalOptions="Center" Spacing="10">
                    <Button Text="Edit Profile" Command="{Binding EditProfileCommand}" IsVisible="{Binding IsEditing, Converter={StaticResource BooleanInverter}}" />
                    <Button Text="Save" Command="{Binding SaveProfileCommand}" IsVisible="{Binding IsEditing}" BackgroundColor="{StaticResource SuccessColor}" TextColor="{StaticResource OnPrimaryColor}" />
                    <Button Text="Cancel" Command="{Binding CancelEditCommand}" IsVisible="{Binding IsEditing}" BackgroundColor="{StaticResource ErrorColor}" TextColor="{StaticResource OnPrimaryColor}" />
                </HorizontalStackLayout>

                <Label Text="{Binding ErrorMessage}" IsVisible="{Binding HasError}" TextColor="{StaticResource ErrorColor}" HorizontalOptions="Center" />
            </VerticalStackLayout>
        </ScrollView>

        <ActivityIndicator IsVisible="{Binding IsBusy}" IsRunning="{Binding IsBusy}" HorizontalOptions="Center" VerticalOptions="Center" />
    </Grid>
</ContentPage>
