<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                   xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Primary Colors (same for both themes) -->
    <Color x:Key="Primary">#512BD4</Color>
    <Color x:Key="PrimaryDark">#3E22A3</Color>
    <Color x:Key="PrimaryLight">#6A44E3</Color>
    <Color x:Key="PrimaryLighter">#8F6EEC</Color>
    <Color x:Key="Secondary">#DFD8F7</Color>
    <Color x:Key="Tertiary">#2B0B98</Color>

    <!--
        Theme-aware colors.

        Each theme-aware resource is declared as three sibling <Color> keys:
          - XxxLight  : the light-theme value
          - XxxDark   : the dark-theme value
          - Xxx       : the "current" value, seeded with the light value and
                        swapped at runtime by ThemeHelper.ApplyThemeColors when
                        the app theme changes.

        Consumers should reference the base key (Xxx) via {DynamicResource Xxx}
        so that theme changes propagate automatically. {StaticResource Xxx} will
        bind to whatever the current value is at parse time.

        This pattern replaces the previous <OnAppTheme> usage. .NET MAUI does
        not expose an OnAppTheme XAML element type (OnAppTheme was renamed to
        AppThemeBinding in Xamarin.Forms 4.7, and MAUI only has the markup
        extension form), so <OnAppTheme> elements fail XAML compilation on
        every platform, including Windows.
    -->

    <!-- Surface / background -->
    <Color x:Key="BackgroundColorLight">#FFFFFF</Color>
    <Color x:Key="BackgroundColorDark">#121212</Color>
    <Color x:Key="BackgroundColor">#FFFFFF</Color>

    <Color x:Key="SurfaceColorLight">#FFFFFF</Color>
    <Color x:Key="SurfaceColorDark">#1E1E1E</Color>
    <Color x:Key="SurfaceColor">#FFFFFF</Color>

    <Color x:Key="SurfaceVariantColorLight">#F1F1F1</Color>
    <Color x:Key="SurfaceVariantColorDark">#252525</Color>
    <Color x:Key="SurfaceVariantColor">#F1F1F1</Color>

    <Color x:Key="SurfaceElevatedColorLight">#FFFFFF</Color>
    <Color x:Key="SurfaceElevatedColorDark">#2D2D2D</Color>
    <Color x:Key="SurfaceElevatedColor">#FFFFFF</Color>

    <Color x:Key="BorderColorLight">#CDCDCD</Color>
    <Color x:Key="BorderColorDark">#393939</Color>
    <Color x:Key="BorderColor">#CDCDCD</Color>

    <!-- Text -->
    <Color x:Key="TextColorLight">#000000</Color>
    <Color x:Key="TextColorDark">#FFFFFF</Color>
    <Color x:Key="TextColor">#000000</Color>

    <Color x:Key="TextSecondaryColorLight">#696969</Color>
    <Color x:Key="TextSecondaryColorDark">#B0B0B0</Color>
    <Color x:Key="TextSecondaryColor">#696969</Color>

    <Color x:Key="TextTertiaryColorLight">#9B9B9B</Color>
    <Color x:Key="TextTertiaryColorDark">#909090</Color>
    <Color x:Key="TextTertiaryColor">#9B9B9B</Color>

    <!-- Cards and dividers -->
    <Color x:Key="CardColorLight">#FFFFFF</Color>
    <Color x:Key="CardColorDark">#2D2D2D</Color>
    <Color x:Key="CardColor">#FFFFFF</Color>

    <Color x:Key="DividerColorLight">#E0E0E0</Color>
    <Color x:Key="DividerColorDark">#333333</Color>
    <Color x:Key="DividerColor">#E0E0E0</Color>

    <!-- Dashboard accents -->
    <Color x:Key="YellowCardColorLight">#FFF8E1</Color>
    <Color x:Key="YellowCardColorDark">#423C00</Color>
    <Color x:Key="YellowCardColor">#FFF8E1</Color>

    <Color x:Key="BlueCardColorLight">#E3F2FD</Color>
    <Color x:Key="BlueCardColorDark">#0A3450</Color>
    <Color x:Key="BlueCardColor">#E3F2FD</Color>

    <Color x:Key="GreenCardColorLight">#E8F5E9</Color>
    <Color x:Key="GreenCardColorDark">#0E3B1C</Color>
    <Color x:Key="GreenCardColor">#E8F5E9</Color>

    <!-- Status colors -->
    <Color x:Key="SuccessColor">#4CAF50</Color>
    <Color x:Key="WarningColor">#FF9800</Color>
    <Color x:Key="ErrorColor">#F44336</Color>

    <Color x:Key="ErrorLightColorLight">#FFEBEE</Color>
    <Color x:Key="ErrorLightColorDark">#4A1C1C</Color>
    <Color x:Key="ErrorLightColor">#FFEBEE</Color>

    <Color x:Key="InfoColor">#2196F3</Color>

    <!-- Static color constants -->
    <Color x:Key="OnPrimaryColor">#FFFFFF</Color>
    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="Black">#000000</Color>

    <!-- Gray scale -->
    <Color x:Key="Gray100Light">#F5F5F5</Color>
    <Color x:Key="Gray100Dark">#2D2D2D</Color>
    <Color x:Key="Gray100">#F5F5F5</Color>

    <Color x:Key="Gray200Light">#EEEEEE</Color>
    <Color x:Key="Gray200Dark">#3A3A3A</Color>
    <Color x:Key="Gray200">#EEEEEE</Color>

    <Color x:Key="Gray300Light">#E0E0E0</Color>
    <Color x:Key="Gray300Dark">#484848</Color>
    <Color x:Key="Gray300">#E0E0E0</Color>

    <Color x:Key="Gray400Light">#BDBDBD</Color>
    <Color x:Key="Gray400Dark">#6D6D6D</Color>
    <Color x:Key="Gray400">#BDBDBD</Color>

    <Color x:Key="Gray500Light">#9E9E9E</Color>
    <Color x:Key="Gray500Dark">#8A8A8A</Color>
    <Color x:Key="Gray500">#9E9E9E</Color>

    <Color x:Key="Gray600Light">#757575</Color>
    <Color x:Key="Gray600Dark">#A0A0A0</Color>
    <Color x:Key="Gray600">#757575</Color>

    <Color x:Key="Gray700Light">#616161</Color>
    <Color x:Key="Gray700Dark">#B8B8B8</Color>
    <Color x:Key="Gray700">#616161</Color>

    <Color x:Key="Gray800Light">#424242</Color>
    <Color x:Key="Gray800Dark">#D0D0D0</Color>
    <Color x:Key="Gray800">#424242</Color>

    <Color x:Key="Gray900Light">#212121</Color>
    <Color x:Key="Gray900Dark">#E8E8E8</Color>
    <Color x:Key="Gray900">#212121</Color>

    <!-- Shadow and elevation -->
    <Color x:Key="ShadowColorLight">#20000000</Color>
    <Color x:Key="ShadowColorDark">#40000000</Color>
    <Color x:Key="ShadowColor">#20000000</Color>

    <Color x:Key="ElevationColorLight">#FFFFFF</Color>
    <Color x:Key="ElevationColorDark">#2D2D2D</Color>
    <Color x:Key="ElevationColor">#FFFFFF</Color>

    <!-- Adaptive aliases (duplicated keys kept for backward compatibility) -->
    <Color x:Key="AdaptiveTextColorLight">#000000</Color>
    <Color x:Key="AdaptiveTextColorDark">#FFFFFF</Color>
    <Color x:Key="AdaptiveTextColor">#000000</Color>

    <Color x:Key="AdaptiveBackgroundColorLight">#FFFFFF</Color>
    <Color x:Key="AdaptiveBackgroundColorDark">#121212</Color>
    <Color x:Key="AdaptiveBackgroundColor">#FFFFFF</Color>

    <Color x:Key="AdaptiveSurfaceColorLight">#FFFFFF</Color>
    <Color x:Key="AdaptiveSurfaceColorDark">#1E1E1E</Color>
    <Color x:Key="AdaptiveSurfaceColor">#FFFFFF</Color>

    <Color x:Key="AdaptiveBorderColorLight">#CDCDCD</Color>
    <Color x:Key="AdaptiveBorderColorDark">#393939</Color>
    <Color x:Key="AdaptiveBorderColor">#CDCDCD</Color>

    <!-- Brushes for properties that require them -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="{DynamicResource BackgroundColor}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{DynamicResource SurfaceColor}" />
    <SolidColorBrush x:Key="TextBrush" Color="{DynamicResource TextColor}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{DynamicResource BorderColor}" />

</ResourceDictionary>
