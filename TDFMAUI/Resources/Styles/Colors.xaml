<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                   xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">
    
    <!-- Primary Colors (same for both themes) -->
    <Color x:Key="Primary">#512BD4</Color>
    <Color x:Key="PrimaryDark">#3E22A3</Color>
    <Color x:Key="PrimaryLight">#6A44E3</Color>
    <Color x:Key="PrimaryLighter">#8F6EEC</Color>
    <Color x:Key="Secondary">#DFD8F7</Color>
    <Color x:Key="Tertiary">#2B0B98</Color>
    
    <!-- Theme-aware colors using OnAppTheme -->
    <OnAppTheme x:Key="BackgroundColor" x:TypeArguments="Color" Light="#FFFFFF" Dark="#121212" />
    <OnAppTheme x:Key="SurfaceColor" x:TypeArguments="Color" Light="#FFFFFF" Dark="#1E1E1E" />
    <OnAppTheme x:Key="SurfaceVariantColor" x:TypeArguments="Color" Light="#F1F1F1" Dark="#252525" />
    <OnAppTheme x:Key="SurfaceElevatedColor" x:TypeArguments="Color" Light="#FFFFFF" Dark="#2D2D2D" />
    <OnAppTheme x:Key="BorderColor" x:TypeArguments="Color" Light="#CDCDCD" Dark="#393939" />
    
    <!-- Text Colors -->
    <OnAppTheme x:Key="TextColor" x:TypeArguments="Color" Light="#000000" Dark="#FFFFFF" />
    <OnAppTheme x:Key="TextSecondaryColor" x:TypeArguments="Color" Light="#696969" Dark="#B0B0B0" />
    <OnAppTheme x:Key="TextTertiaryColor" x:TypeArguments="Color" Light="#9B9B9B" Dark="#909090" />
    
    <!-- Card and Divider -->
    <OnAppTheme x:Key="CardColor" x:TypeArguments="Color" Light="#FFFFFF" Dark="#2D2D2D" />
    <OnAppTheme x:Key="DividerColor" x:TypeArguments="Color" Light="#E0E0E0" Dark="#333333" />
    
    <!-- Dashboard Colors -->
    <OnAppTheme x:Key="YellowCardColor" x:TypeArguments="Color" Light="#FFF8E1" Dark="#423C00" />
    <OnAppTheme x:Key="BlueCardColor" x:TypeArguments="Color" Light="#E3F2FD" Dark="#0A3450" />
    <OnAppTheme x:Key="GreenCardColor" x:TypeArguments="Color" Light="#E8F5E9" Dark="#0E3B1C" />
    
    <!-- Status Colors -->
    <Color x:Key="SuccessColor">#4CAF50</Color>
    <Color x:Key="WarningColor">#FF9800</Color>
    <Color x:Key="ErrorColor">#F44336</Color>
    <OnAppTheme x:Key="ErrorLightColor" x:TypeArguments="Color" Light="#FFEBEE" Dark="#4A1C1C" />
    <Color x:Key="InfoColor">#2196F3</Color>
    
    <!-- Additional Colors -->
    <Color x:Key="OnPrimaryColor">#FFFFFF</Color>
    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="Black">#000000</Color>
    
    <!-- Gray Colors for compatibility -->
    <OnAppTheme x:Key="Gray100" x:TypeArguments="Color" Light="#F5F5F5" Dark="#2D2D2D" />
    <OnAppTheme x:Key="Gray200" x:TypeArguments="Color" Light="#EEEEEE" Dark="#3A3A3A" />
    <OnAppTheme x:Key="Gray300" x:TypeArguments="Color" Light="#E0E0E0" Dark="#484848" />
    <OnAppTheme x:Key="Gray400" x:TypeArguments="Color" Light="#BDBDBD" Dark="#6D6D6D" />
    <OnAppTheme x:Key="Gray500" x:TypeArguments="Color" Light="#9E9E9E" Dark="#8A8A8A" />
    <OnAppTheme x:Key="Gray600" x:TypeArguments="Color" Light="#757575" Dark="#A0A0A0" />
    <OnAppTheme x:Key="Gray700" x:TypeArguments="Color" Light="#616161" Dark="#B8B8B8" />
    <OnAppTheme x:Key="Gray800" x:TypeArguments="Color" Light="#424242" Dark="#D0D0D0" />
    <OnAppTheme x:Key="Gray900" x:TypeArguments="Color" Light="#212121" Dark="#E8E8E8" />
    
    <!-- Shadow and Elevation -->
    <OnAppTheme x:Key="ShadowColor" x:TypeArguments="Color" Light="#20000000" Dark="#40000000" />
    <OnAppTheme x:Key="ElevationColor" x:TypeArguments="Color" Light="#FFFFFF" Dark="#2D2D2D" />

    <!-- Adaptive Resources for dynamic updates -->
    <OnAppTheme x:Key="AdaptiveTextColor" x:TypeArguments="Color" Light="#000000" Dark="#FFFFFF" />
    <OnAppTheme x:Key="AdaptiveBackgroundColor" x:TypeArguments="Color" Light="#FFFFFF" Dark="#121212" />
    <OnAppTheme x:Key="AdaptiveSurfaceColor" x:TypeArguments="Color" Light="#FFFFFF" Dark="#1E1E1E" />
    <OnAppTheme x:Key="AdaptiveBorderColor" x:TypeArguments="Color" Light="#CDCDCD" Dark="#393939" />

    <!-- Brushes for properties that require them -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="{DynamicResource BackgroundColor}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{DynamicResource SurfaceColor}" />
    <SolidColorBrush x:Key="TextBrush" Color="{DynamicResource TextColor}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{DynamicResource BorderColor}" />
    
</ResourceDictionary>
