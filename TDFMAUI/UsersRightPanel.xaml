<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:TDFMAUI.ViewModels"
             xmlns:helpers="clr-namespace:TDFMAUI.Helpers"
             x:Class="TDFMAUI.UsersRightPanel"
             x:DataType="viewmodels:UsersRightPanelViewModel"
             BackgroundColor="White">
    <Grid RowDefinitions="Auto, *, Auto" Padding="15">
        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,15">
            <Label Grid.Column="0" Text="Online Users" FontSize="20" FontAttributes="Bold" VerticalOptions="Center" />
            <Button Grid.Column="1" Text="✕" Clicked="ClosePanel_Clicked" BackgroundColor="Transparent" TextColor="{StaticResource Primary}" FontSize="20" WidthRequest="40" HeightRequest="40" />
        </Grid>

        <!-- Offline indicator -->
        <Label Grid.Row="1" Text="Device is offline. Showing cached users." IsVisible="{Binding IsOffline}" TextColor="Red" FontSize="12" HorizontalOptions="Center" Margin="0,0,0,10" />

        <!-- User List -->
        <RefreshView Grid.Row="1" Command="{Binding RefreshUsersCommand}" IsRefreshing="{Binding IsRefreshing}">
            <CollectionView ItemsSource="{Binding Users}" EmptyView="No users online">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="viewmodels:UserViewModel">
                        <Grid ColumnDefinitions="Auto, *" Padding="0,8">
                            <Frame BackgroundColor="{Binding StatusColor}" WidthRequest="12" HeightRequest="12" CornerRadius="6" Padding="0" VerticalOptions="Center" Margin="0,0,10,0" />
                            <VerticalStackLayout Grid.Column="1">
                                <Label Text="{Binding FullName}" FontSize="14" FontAttributes="Bold" />
                                <Label Text="{Binding Department}" FontSize="12" TextColor="{DynamicResource Gray600}" />
                            </VerticalStackLayout>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <!-- Pagination -->
        <HorizontalStackLayout Grid.Row="2" HorizontalOptions="Center" Spacing="20" Margin="0,15,0,0" IsVisible="{Binding HasPagination}">
            <Button Text="◀" Command="{Binding LoadPreviousPageCommand}" IsEnabled="{Binding HasPreviousPage}" BackgroundColor="Transparent" TextColor="{StaticResource Primary}" />
            <Label Text="{Binding CurrentPage}" VerticalOptions="Center" FontAttributes="Bold" />
            <Button Text="▶" Command="{Binding LoadNextPageCommand}" IsEnabled="{Binding HasNextPage}" BackgroundColor="Transparent" TextColor="{StaticResource Primary}" />
        </HorizontalStackLayout>
        
        <ActivityIndicator Grid.Row="1" IsVisible="{Binding IsBusy}" IsRunning="{Binding IsBusy}" Color="{StaticResource Primary}" HorizontalOptions="Center" VerticalOptions="Center" />
    </Grid>
</ContentPage>
